generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  role            String           @default("EMPLOYEE") // EMPLOYEE ou MANAGER
  shifts          Shift[]
  timeOffRequests TimeOffRequest[]
}

model TimeOffRequest {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  date     DateTime
  status   String   @default("PENDING") // PENDING, APPROVED, REJECTED
}

model Shift {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime
  startTime DateTime
  endTime   DateTime
}

model Room {
  id         String      @id @default(uuid())
  name       String
  capacity   Int
  screenings Screening[]
}

model Movie {
  id          String      @id @default(uuid())
  tmdbId      String?     @unique
  title       String
  durationMin Int
  posterUrl   String?
  description String?
  screenings  Screening[]
}

model Screening {
  id        String   @id @default(uuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id])
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id])
  startTime DateTime
  bufferMin Int      @default(15)
  endTime   DateTime
}
